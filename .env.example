# Copy to .env and fill in (optional — or use: huggingface-cli login)
HF_TOKEN=hf_your_token_here

# Optional overrides
PROMPTFUSE_CONFIG=configs/demo.yaml
# PromptFuse / demo scripts only (do NOT export as VLLM_URL — vLLM warns on unknown env vars)
PF_BACKEND_URL=http://localhost:8000
PROMPTFUSE_URL=http://localhost:8080
